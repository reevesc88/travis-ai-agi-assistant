{
  "name": "@clawnify/open-fieldservice",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler d1 execute open-fieldservice-db --local --file=src/server/schema.sql && concurrently -n ui,api -c cyan,green \"vite\" \"wrangler dev --port 8787\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clawnify/db": "^0.2.0",
    "@hono/zod-openapi": "^0.18.0",
    "hono": "^4.12.25",
    "lucide-preact": "^0.575.0",
    "preact": "^10.25.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.3",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
